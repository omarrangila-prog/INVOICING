<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Customer Account Sequence -->
        <record id="seq_customer_account" model="ir.sequence">
            <field name="name">Customer Account Sequence</field>
            <field name="code">customer.account.sequence</field>
            <field name="prefix">CUST/%(year)s/</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">5</field>
        </record>

        <!-- Item Master Sequence -->
        <record id="seq_item_master" model="ir.sequence">
            <field name="name">Item Master Sequence</field>
            <field name="code">item.master.sequence</field>
            <field name="prefix">ITEM/%(year)s/</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">5</field>
        </record>

        <!-- Digital Invoice Sequence -->
        <record id="seq_digital_invoice" model="ir.sequence">
            <field name="name">Digital Invoice Sequence</field>
            <field name="code">digital.invoice.sequence</field>
            <field name="prefix">INV/%(year)s/%(month)s/</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">6</field>
        </record>

    </data>
</odoo>
