<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_digital_invoice_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">digital.invoice.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'no_breadcrumbs': True}</field>
    </record>

    <record id="action_customer_account_window" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">customer.account</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>

    <record id="action_customer_category_window" model="ir.actions.act_window">
        <field name="name">Customer Categories</field>
        <field name="res_model">customer.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_customer_subcategory_window" model="ir.actions.act_window">
        <field name="name">Customer Sub Categories</field>
        <field name="res_model">customer.subcategory</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_item_master_window" model="ir.actions.act_window">
        <field name="name">Items</field>
        <field name="res_model">item.master</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>

    <record id="action_item_category_window" model="ir.actions.act_window">
        <field name="name">Item Categories</field>
        <field name="res_model">item.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_item_subcategory_window" model="ir.actions.act_window">
        <field name="name">Item Sub Categories</field>
        <field name="res_model">item.subcategory</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_item_uom_window" model="ir.actions.act_window">
        <field name="name">Units of Measure</field>
        <field name="res_model">item.uom</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_item_hs_code_window" model="ir.actions.act_window">
        <field name="name">HS Codes</field>
        <field name="res_model">item.hs.code</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_digital_invoice_window" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">digital.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>

    <record id="action_digital_buyer_window" model="ir.actions.act_window">
        <field name="name">Buyers</field>
        <field name="res_model">digital.buyer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_digital_scenario_window" model="ir.actions.act_window">
        <field name="name">Scenarios</field>
        <field name="res_model">digital.scenario</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_digital_invoice_book_window" model="ir.actions.act_window">
        <field name="name">Digital Invoice Book</field>
        <field name="res_model">digital.invoice.book</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_fbr_log_window" model="ir.actions.act_window">
        <field name="name">FBR Logs</field>
        <field name="res_model">digital.fbr.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>

</odoo>