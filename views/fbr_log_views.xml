<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FBR Log List View -->
    <record id="view_fbr_log_tree" model="ir.ui.view">
        <field name="name">digital.fbr.log.tree</field>
        <field name="model">digital.fbr.log</field>
        <field name="arch" type="xml">
            <list string="FBR Logs" create="0" edit="0" delete="0"
                  decoration-success="status == 'success'"
                  decoration-danger="status == 'failed'">
                <field name="create_date" string="Date/Time"/>
                <field name="invoice_number" string="Invoice No"/>
                <field name="action_type" string="Action"
                       widget="badge"
                       decoration-info="action_type == 'validate'"
                       decoration-success="action_type == 'post'"/>
                <field name="status" string="Status"
                       widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'failed'"/>
                <field name="fbr_invoice_number" string="FBR Invoice No" optional="show"/>
                <field name="fbr_date" string="FBR Date" optional="show"/>
                <field name="create_uid" string="Called By" optional="show"/>
                <field name="error_message" string="Error" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- FBR Log Form View -->
    <record id="view_fbr_log_form" model="ir.ui.view">
        <field name="name">digital.fbr.log.form</field>
        <field name="model">digital.fbr.log</field>
        <field name="arch" type="xml">
            <form string="FBR Log" create="0" edit="0" delete="0">
                <sheet>

                    <!-- Ribbons -->
                    <widget name="web_ribbon" title="Validated" bg_color="bg-primary"
                            invisible="action_type != 'validate' or status != 'success'"/>
                    <widget name="web_ribbon" title="Posted" bg_color="bg-success"
                            invisible="action_type != 'post' or status != 'success'"/>
                    <widget name="web_ribbon" title="Failed" bg_color="bg-danger"
                            invisible="status != 'failed'"/>

                    <!-- Header -->
                    <div class="o_cust_header">

                        <!-- Status Avatar -->
                        <div class="o_fbr_log_avatar_success" invisible="status != 'success'">
                            &#10003;
                        </div>
                        <div class="o_fbr_log_avatar_failed" invisible="status != 'failed'">
                            &#10007;
                        </div>

                        <!-- Info Card -->
                        <div class="o_cust_info_card">
                            <h1 class="o_cust_name">
                                <field name="invoice_number" readonly="1"/>
                            </h1>
                            <div class="o_cust_meta_row">
                                <field name="action_type" widget="badge"
                                       decoration-info="action_type == 'validate'"
                                       decoration-success="action_type == 'post'"
                                       readonly="1"/>
                                <field name="status" widget="badge"
                                       decoration-success="status == 'success'"
                                       decoration-danger="status == 'failed'"
                                       readonly="1"/>
                                <span class="o_cust_province_chip">
                                    &#128336; <field name="create_date" readonly="1" nolabel="1"
                                                    class="o_cust_province_inline"/>
                                </span>
                                <span class="o_cust_province_chip" invisible="not create_uid">
                                    &#128100; <field name="create_uid" readonly="1" nolabel="1"
                                                    class="o_cust_province_inline"/>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="o_cust_divider"/>

                    <!-- Call Details + FBR Response -->
                    <div class="o_cust_grid_2">

                        <div class="o_cust_card">
                            <div class="o_cust_card_title">&#128222; Call Details</div>
                            <group>
                                <field name="action_type" string="Action"/>
                                <field name="status" string="Status"/>
                                <field name="invoice_id" string="Invoice Record"/>
                            </group>
                        </div>

                        <!-- Success response card -->
                        <div class="o_cust_card o_cust_card_blue" invisible="status != 'success'">
                            <div class="o_cust_card_title o_title_blue">&#10003; FBR Response</div>
                            <group>
                                <field name="fbr_invoice_number" string="FBR Invoice No"/>
                                <field name="fbr_date" string="FBR Date"/>
                            </group>
                        </div>

                        <!-- Failed error card -->
                        <div class="o_cust_card o_fbr_error_card" invisible="status != 'failed'">
                            <div class="o_cust_card_title o_title_red">&#9888; Error Details</div>
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </div>

                    </div>

                    <div class="o_cust_divider"/>

                    <!-- API URL -->
                    <div class="o_cust_card">
                        <div class="o_cust_card_title">&#127760; API Endpoint</div>
                        <div style="font-family:'Courier New',monospace; font-size:12px; color:#2563eb; word-break:break-all; overflow-wrap:break-word;">
                            <field name="url" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <div class="o_cust_divider"/>

                    <!-- Request Payload -->
                    <div class="o_cust_card o_fbr_payload_card">
                        <div class="o_cust_card_title" style="color:#3730a3;">&#8593; Request Payload (Sent to FBR)</div>
                        <div style="font-family:'Courier New',Courier,monospace; font-size:11px; line-height:1.6; white-space:pre-wrap; word-break:break-all; overflow-wrap:break-word; overflow-y:auto; max-height:250px; background:rgba(0,0,0,0.04); border-radius:6px; padding:10px; margin-top:4px;">
                            <field name="request_payload" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <div class="o_cust_divider"/>

                    <!-- Response Success -->
                    <div class="o_cust_card o_fbr_response_success" invisible="status != 'success'">
                        <div class="o_cust_card_title o_title_green">&#8595; FBR Response (Success)</div>
                        <div style="font-family:'Courier New',Courier,monospace; font-size:11px; line-height:1.6; white-space:pre-wrap; word-break:break-all; overflow-wrap:break-word; overflow-y:auto; max-height:250px; background:rgba(0,0,0,0.04); border-radius:6px; padding:10px; margin-top:4px;">
                            <field name="response_raw" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <!-- Response Failed -->
                    <div class="o_cust_card o_fbr_response_failed" invisible="status != 'failed'">
                        <div class="o_cust_card_title o_title_red">&#8595; FBR Response (Failed)</div>
                        <div style="font-family:'Courier New',Courier,monospace; font-size:11px; line-height:1.6; white-space:pre-wrap; word-break:break-all; overflow-wrap:break-word; overflow-y:auto; max-height:250px; background:rgba(0,0,0,0.04); border-radius:6px; padding:10px; margin-top:4px;">
                            <field name="response_raw" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- FBR Log Search View -->
    <record id="view_fbr_log_search" model="ir.ui.view">
        <field name="name">digital.fbr.log.search</field>
        <field name="model">digital.fbr.log</field>
        <field name="arch" type="xml">
            <search string="Search FBR Logs">
                <field name="invoice_number" string="Invoice Number"/>
                <field name="fbr_invoice_number" string="FBR Invoice No"/>
                <field name="create_uid" string="Called By"/>
                <filter name="success" string="Success" domain="[('status', '=', 'success')]"/>
                <filter name="failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <filter name="validate" string="Validate" domain="[('action_type', '=', 'validate')]"/>
                <filter name="post" string="Post" domain="[('action_type', '=', 'post')]"/>
                <filter name="today" string="Today"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_action" string="Action" context="{'group_by': 'action_type'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>